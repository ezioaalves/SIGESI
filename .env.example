GOOGLE_CLIENT_ID="You google client id"
GOOGLE_CLIENT_SECRET="Your google client secret"
APP_PUBLIC_URL=http://localhost:3000
APP_DOMAIN=:80
APP_CORS_ALLOWED_ORIGINS=http://localhost:3000
OAUTH2_SUCCESS_REDIRECT=http://localhost:3000/portal
OAUTH2_FAILURE_REDIRECT=http://localhost:3000/?authError=usuario_inativo
OAUTH2_LOGOUT_REDIRECT=http://localhost:3000
DATABASE_URL=jdbc:postgresql://db:5432/db_app
DB_NAME=database_name
DATABASE_NAME=database_name
DATABASE_USER=user
DATABASE_PASSWORD=password

# MinIO Configuration
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

ADMIN_EMAIL=admin@example.com

# RabbitMQ Configuration
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest

# Docker image configuration used by compose-prod.yaml
DOCKERHUB_USERNAME=your-dockerhub-user
IMAGE_TAG=latest
